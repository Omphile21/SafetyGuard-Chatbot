<Window x:Class="safety_chatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OMNI Cybersecurity Assistant"
        Height="720"
        Width="1050"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="110"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="33.498"/>
            <RowDefinition Height="51.502"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#111827"
                CornerRadius="20"
                BorderBrush="#38BDF8"
                BorderThickness="2">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="90"
                        Height="90"
                        CornerRadius="45"
                        Background="#1E293B"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="10,0,0,0">

                    <Image x:Name="imgLogo"
                           Height="70"
                           Stretch="Uniform"
                           Source="Omni SafetyChatbot.png" Margin="10,10,0,10"/>
                </Border>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">

                    <TextBlock Text="OMNI"
                               FontSize="38"
                               FontWeight="Bold"
                               Foreground="#38BDF8"/>

                    <TextBlock Text="Cybersecurity Awareness Assistant"
                               FontSize="17"
                               Foreground="White"/>

                    <TextBlock Text="Stay Safe. Stay Smart. Stay Secure."
                               FontSize="13"
                               Foreground="LightGray"/>
                </StackPanel>

            </Grid>
        </Border>

        <!-- TABS -->
        <TabControl Grid.Row="1"
                    Margin="0,20,0,20">

            <!-- CHAT -->
            <TabItem Header="Chat">

                <Border Background="#111827"
                        Padding="15">

                    <RichTextBox x:Name="rtbChat"
                                 Background="#111827"
                                 Foreground="White"
                                 FontSize="15"
                                 BorderThickness="0"
                                 VerticalScrollBarVisibility="Auto"
                                 IsReadOnly="True"/>
                </Border>

            </TabItem>

            <!-- TASK ASSISTANT -->
            <TabItem Header="Task Assistant">

                <Grid Margin="20">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="60"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBox x:Name="txtTaskTitle"
                             Grid.Row="0"
                             Margin="5"
                             FontSize="15"
                             VerticalContentAlignment="Center"/>

                    <TextBox x:Name="txtTaskDescription"
                             Grid.Row="1"
                             Margin="5"
                             FontSize="15"
                             VerticalContentAlignment="Center"/>

                    <DatePicker x:Name="dpReminder"
                                Grid.Row="2"
                                Margin="5"/>

                    <StackPanel Grid.Row="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center">

                        <Button x:Name="btnAddTask"
                                Content="Add Task"
                                Width="120"
                                Margin="5"
                                Click="btnAddTask_Click"/>

                        <Button x:Name="btnCompleteTask"
                                Content="Complete"
                                Width="120"
                                Margin="5"
                                Click="btnCompleteTask_Click"/>

                        <Button x:Name="btnDeleteTask"
                                Content="Delete"
                                Width="120"
                                Margin="5"
                                Click="btnDeleteTask_Click"/>

                    </StackPanel>

                    <ListBox x:Name="lstTasks"
                             Grid.Row="4"
                             Margin="5"/>

                </Grid>

            </TabItem>

            <!-- QUIZ -->
            <TabItem Header="Cyber Quiz">

                <Grid Margin="20">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="100"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="70"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="lblQuestion"
                               Grid.Row="0"
                               FontSize="20"
                               TextWrapping="Wrap"/>

                    <RadioButton x:Name="rb1"
                                 Grid.Row="1"
                                 FontSize="16"/>

                    <RadioButton x:Name="rb2"
                                 Grid.Row="2"
                                 FontSize="16"/>

                    <RadioButton x:Name="rb3"
                                 Grid.Row="3"
                                 FontSize="16"/>

                    <RadioButton x:Name="rb4"
                                 Grid.Row="4"
                                 FontSize="16"/>

                    <Button x:Name="btnAnswer"
                            Grid.Row="5"
                            Content="Submit Answer"
                            Width="200"
                            Height="45"
                            HorizontalAlignment="Center"
                            Click="btnAnswer_Click"/>

                </Grid>

            </TabItem>

            <!-- ACTIVITY LOG -->
            <TabItem Header="Activity Log">

                <Grid Margin="20">

                    <ListBox x:Name="lstActivityLog"/>

                </Grid>

            </TabItem>

        </TabControl>

        <!-- INPUT AREA -->
        <Border Grid.Row="1"
                Background="#111827"
                CornerRadius="20"
                Padding="10"
                BorderBrush="#38BDF8"
                BorderThickness="2" Margin="0,479,0,0" Grid.RowSpan="3">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="txtUserInput"
                         Grid.Column="0"
                         Height="50"
                         FontSize="15"
                         Padding="12"
                         VerticalContentAlignment="Center"
                         Background="#1E293B"
                         Foreground="White"
                         BorderThickness="0"
                         CaretBrush="White"
                         Margin="0,0,10,0"/>

                <Button x:Name="btnSend"
                        Grid.Column="1"
                        Content="SEND"
                        FontSize="16"
                        FontWeight="Bold"
                        Background="#06B6D4"
                        Foreground="White"
                        Height="50"
                        Click="btnSend_Click"/>

            </Grid>

        </Border>

    </Grid>

</Window>