<Window x:Class="safety_chatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:safety_chatbot"
        mc:Ignorable="d"
        Title="OMNI Cybersecurity Assistant"
        Height="720"
        Width="1050"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="110"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="85"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#111827"
                CornerRadius="20"
                BorderBrush="#38BDF8"
                BorderThickness="2">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LOGO -->
                <Border Width="90"
                        Height="90"
                        CornerRadius="45"
                        Background="#1E293B"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="10,0,0,0">

                    <Image x:Name="imgLogo"
                           Width="70"
                           Height="70"
                           Stretch="Uniform"
                           Source="Omni SafetyChatbot.png"/>
                </Border>

                <!-- TITLE SECTION -->
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Margin="10,0,0,0">

                    <TextBlock Text="OMNI"
                               FontSize="38"
                               FontWeight="Bold"
                               Foreground="#38BDF8"/>

                    <TextBlock Text="Cybersecurity Awareness Assistant"
                               FontSize="17"
                               Foreground="White"
                               Margin="0,5,0,0"/>

                    <TextBlock Text="Stay Safe. Stay Smart. Stay Secure."
                               FontSize="13"
                               Foreground="LightGray"
                               Margin="0,5,0,0"/>
                </StackPanel>

            </Grid>
        </Border>

        <!-- CHAT AREA -->
        <Border Grid.Row="1"
                Background="#111827"
                CornerRadius="20"
                Padding="15"
                Margin="0,20,0,20"
                BorderBrush="#1E40AF"
                BorderThickness="2">

            <RichTextBox x:Name="rtbChat"
                         Background="#111827"
                         Foreground="White"
                         FontSize="15"
                         BorderThickness="0"
                         VerticalScrollBarVisibility="Auto"
                         IsReadOnly="True"/>
        </Border>

        <!-- INPUT AREA -->
        <Border Grid.Row="2"
                Background="#111827"
                CornerRadius="20"
                Padding="10"
                BorderBrush="#38BDF8"
                BorderThickness="2">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <!-- USER INPUT -->
                <TextBox x:Name="txtUserInput"
                         Grid.Column="0"
                         Height="50"
                         FontSize="15"
                         Padding="12"
                         VerticalContentAlignment="Center"
                         Background="#1E293B"
                         Foreground="White"
                         BorderThickness="0"
                         CaretBrush="White"
                         Margin="0,0,10,0"/>

                <!-- SEND BUTTON -->
                <Button x:Name="btnSend"
                        Grid.Column="1"
                        Content="SEND"
                        FontSize="16"
                        FontWeight="Bold"
                        Background="#06B6D4"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Height="50"
                        Click="btnSend_Click">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">

                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="12">

                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>

                </Button>

            </Grid>
        </Border>

    </Grid>
    </Window>